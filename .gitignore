# Python .gitignore template

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/
wheels/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
ENV/
env/
.venv/
.env/
env.bak/
venv.bak/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml

# Translations
*.mo
*.pot

# Django / Flask / general local files
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
instance/
.webassets-cache

# Sphinx
docs/_build/

# Jupyter
.ipynb_checkpoints/

# IPython
profile_default/
ipython_config.py

# PyBuilder
target/

# pyenv
.python-version

# pipenv
Pipfile.lock

# mypy / pylance / type caches
.mypy_cache/
.pyre/

# Cython debug
cython_debug/

# Editors and IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.spyderproject
.spyproject
.ropeproject

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs and temp files
*.log
*.tmp
*.bak
*~
*.swp
*.swo
.#*

# Static / node modules (if applicable)
node_modules/

# Secrets and credentials
.env
.env.* 